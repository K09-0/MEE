# ==========================================
# MEE App - Environment Configuration
# Copy this file to .env.development or .env.production
# ==========================================

# ------------------------------------------
# AI Service API Keys
# ------------------------------------------
HUGGING_FACE_API_KEY=your_huggingface_api_key_here
REPLICATE_API_KEY=your_replicate_api_key_here
STABILITY_API_KEY=your_stability_api_key_here

# ------------------------------------------
# Payment Configuration
# ------------------------------------------
# Stripe (Test keys for development)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Solana (Devnet for development, Mainnet for production)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PLATFORM_WALLET=your_platform_wallet_address

# TON Connect
TON_MANIFEST_URL=https://yourdomain.com/ton-manifest.json

# ------------------------------------------
# App Configuration
# ------------------------------------------
# API Base URL
API_BASE_URL=https://api-dev.mee.app

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false
ENABLE_PAYMENTS=true

# App Version
APP_VERSION=1.0.0
BUILD_NUMBER=1

# ------------------------------------------
# Firebase Configuration (Auto-generated by FlutterFire)
# These are typically auto-configured via firebase_options.dart
# Only add if you need to override defaults
# ------------------------------------------
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_API_KEY=your_api_key
# FIREBASE_APP_ID=your_app_id
# FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# ------------------------------------------
# Social Media (for sharing)
# ------------------------------------------
TWITTER_HANDLE=@mee_app
INSTAGRAM_HANDLE=@mee.app
TIKTOK_HANDLE=@mee.app

# ------------------------------------------
# Support & Legal
# ------------------------------------------
SUPPORT_EMAIL=support@mee.app
PRIVACY_POLICY_URL=https://mee.app/privacy
TERMS_OF_SERVICE_URL=https://mee.app/terms
